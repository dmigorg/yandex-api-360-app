{
  "name": "@dmigorg/yandex-api-360",
  "version": "1.0.2",
  "description": "TypeScript client for Yandex 360 for Business API",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && bunx tsc --emitDeclarationOnly",
    "typecheck": "bunx tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "typescript": "^5",
    "@types/bun": "latest"
  },
  "keywords": [
    "yandex",
    "yandex-360",
    "api-client",
    "typescript",
    "directory",
    "users",
    "departments"
  ],
  "license": "MIT",
  "author": "dmigorg",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dmigorg/yandex-api-360-app"
  },
  "homepage": "https://github.com/dmigorg/yandex-api-360-app#readme",
  "bugs": {
    "url": "https://github.com/dmigorg/yandex-api-360-app/issues"
  }
}
